{
  "name": "nexus-league",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm clean:test-drafts && turbo dev --output-logs=full",
    "clean:test-drafts": "pnpm --filter @nexus/db db:clean-test",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @nexus/db db:generate",
    "db:push": "pnpm --filter @nexus/db db:push",
    "db:migrate": "pnpm --filter @nexus/db db:migrate",
    "db:seed": "pnpm --filter @nexus/db db:seed",
    "db:studio": "pnpm --filter @nexus/db db:studio",
    "test:draft": "pnpm --filter @nexus/db db:seed:draft"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
