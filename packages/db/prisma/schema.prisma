generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  TEAM_CAPTAIN
  ADMIN
}

enum PlayerRole {
  TOP
  JUNGLE
  MID
  ADC
  SUPPORT
}

enum ContractStatus {
  PENDING_APPROVAL
  ACTIVE
  EXPIRED
  TERMINATED
  LOAN
}

enum MatchFormat {
  BO1
  BO3
  BO5
}

enum MatchResult {
  WIN
  LOSS
}

enum TransferOfferStatus {
  PENDING
  COUNTER_PROPOSED
  ACCEPTED
  VALIDATED_ADMIN
  CONTRACT_IN_PROGRESS
  FINALIZED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ConversionDirection {
  TRANSFER_TO_SALARY
  SALARY_TO_TRANSFER
}

enum DraftStatus {
  LOBBY
  COINFLIP
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum DraftActionType {
  BAN
  PICK
}

enum DraftSide {
  BLUE
  RED
}

enum CoinflipDecision {
  SIDE_BLUE
  SIDE_RED
  FIRST_PICK
  SECOND_PICK
}

enum DraftParticipantRole {
  BLUE_CAPTAIN
  RED_CAPTAIN
  SPECTATOR
  ADMIN
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  role                UserRole             @default(USER)
  captainOfTeamId     String?
  captainOfTeam       Team?                @relation("TeamCaptains", fields: [captainOfTeamId], references: [id], onDelete: SetNull)
  walletBalance       Int                  @default(0)
  linkedPlayerId      String?              @unique
  linkedPlayer        Player?              @relation("PlayerAccount", fields: [linkedPlayerId], references: [id], onDelete: SetNull)
  walletTransactions  WalletTransaction[]
  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  marketValueChanges  MarketValueHistory[] @relation("MarketValueChangedBy")
  notifications       Notification[]
  articles            Article[]            @relation("ArticleAuthor")
  createdDrafts       Draft[]              @relation("DraftCreatedBy")
  draftParticipations DraftParticipant[]
  bets                Bet[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([role])
  @@index([captainOfTeamId])
}

model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  coverImageUrl String?
  body          String
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  publishedAt   DateTime?
  authorId      String
  author        User      @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@index([isFeatured])
  @@index([authorId])
}

model Team {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  shortCode         String             @unique
  logoUrl           String?
  transferBudget    Int                @default(1200000)
  salaryBudgetCap   Int                @default(1200000)
  captains          User[]             @relation("TeamCaptains")
  players           Player[]
  homeMatches       Match[]            @relation("HomeTeam")
  awayMatches       Match[]            @relation("AwayTeam")
  wonMatches        Match[]            @relation("WinnerTeam")
  blueSideGames     MatchGame[]        @relation("BlueSideTeam")
  redSideGames      MatchGame[]        @relation("RedSideTeam")
  wonGames          MatchGame[]        @relation("GameWinnerTeam")
  contracts         Contract[]
  teamTrophies      Trophy[]           @relation("TeamTrophies")
  playerMatchStats  PlayerMatchStats[]
  outgoingTransfers TransferOffer[]    @relation("BuyingTeam")
  incomingTransfers TransferOffer[]    @relation("SellingTeam")
  budgetConversions BudgetConversion[]
  teamRatings       TeamRating[]
  betsSelected      Bet[]              @relation("BetSelectedTeam")
  blueDrafts           Draft[]         @relation("BlueTeamDrafts")
  redDrafts            Draft[]         @relation("RedTeamDrafts")
  coinflipWinnerDrafts Draft[]         @relation("CoinflipWinnerTeamDrafts")
  wonDrafts            Draft[]         @relation("WonDrafts")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Player {
  id                 String               @id @default(cuid())
  firstName          String
  lastName           String
  slug               String               @unique
  gameName           String
  tagLine            String
  puuid              String?              @unique
  summonerId         String?              @unique
  imageUrl           String?
  role               PlayerRole
  teamRole           PlayerRole?
  secondaryRoles     PlayerRole[]         @default([])
  age                Int?
  nationality        String?
  marketValue        Int                  @default(0)
  // Moteur d'évolution de valeur : forme moyenne mobile (0..100) et volatilité
  // (EMA de |note - baseline|). `marketValue` porte la valeur, bornée [10M, 55M].
  baseline           Float                @default(50)
  volatility         Float                @default(8)
  salary             Int                  @default(0)
  cost               Int                  @default(1)
  isActive           Boolean              @default(true)
  teamId             String?
  team               Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  linkedAccount      User?                @relation("PlayerAccount")
  contracts          Contract[]
  marketValueHistory MarketValueHistory[]
  playerMatchStats   PlayerMatchStats[]
  playerTrophies     Trophy[]             @relation("PlayerTrophies")
  transferOffers     TransferOffer[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([gameName, tagLine])
  @@index([teamId])
  @@index([teamId, role])
  @@index([marketValue])
}

model Contract {
  id               String          @id @default(cuid())
  playerId         String
  teamId           String
  status           ContractStatus  @default(PENDING_APPROVAL)
  salary           Int
  durationBo3      Int             @default(10)
  bosRemaining     Int?
  releaseClause    Int
  transferFee      Int?
  approvedAt       DateTime?
  terminatedAt     DateTime?
  expiresAt        DateTime?
  expiryNotifiedAt DateTime?
  notes            String?
  player           Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team             Team            @relation(fields: [teamId], references: [id], onDelete: Restrict)
  transferOffers   TransferOffer[] @relation("ContractTransfer")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([playerId, teamId, createdAt])
  @@index([playerId, status])
  @@index([teamId, status])
  @@index([status, expiresAt])
  @@index([teamId, status, bosRemaining])
}

model Season {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  year      Int
  isCurrent Boolean  @default(false)
  startDate DateTime
  endDate   DateTime
  matches       Match[]
  trophies      Trophy[]
  drafts        Draft[]
  teamRatings   TeamRating[]
  bettingConfig BettingConfig?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, slug])
  @@index([isCurrent])
}

model Match {
  id           String      @id @default(cuid())
  seasonId     String
  homeTeamId   String
  awayTeamId   String
  winnerTeamId String?
  format       MatchFormat
  scheduledAt  DateTime
  playedAt     DateTime?
  isCompleted  Boolean     @default(false)
  homeScore    Int         @default(0)
  awayScore    Int         @default(0)
  notes        String?
  season       Season      @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  winnerTeam   Team?       @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  games        MatchGame[]
  drafts       Draft[]
  odds         MatchOdds?
  bets         Bet[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([seasonId, homeTeamId, awayTeamId, scheduledAt])
  @@index([seasonId, scheduledAt])
  @@index([homeTeamId, awayTeamId])
  @@index([winnerTeamId])
}

model MatchGame {
  id              String             @id @default(cuid())
  matchId         String
  gameNumber      Int
  riotMatchId     String?            @unique
  blueTeamId      String
  redTeamId       String
  winnerTeamId    String?
  playedAt        DateTime?
  durationSeconds Int?
  // Snapshot des totaux d'équipe issus du replay, nécessaires aux sous-scores
  // objectifs (#10) et au contexte de domination de la note (§4.4/§4.7).
  blueTotalGold      Int?
  redTotalGold       Int?
  blueDragonKills    Int?
  blueBaronKills     Int?
  blueTurretKills    Int?
  blueInhibitorKills Int?
  redDragonKills     Int?
  redBaronKills      Int?
  redTurretKills     Int?
  redInhibitorKills  Int?
  match           Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  blueTeam        Team               @relation("BlueSideTeam", fields: [blueTeamId], references: [id], onDelete: Restrict)
  redTeam         Team               @relation("RedSideTeam", fields: [redTeamId], references: [id], onDelete: Restrict)
  winnerTeam      Team?              @relation("GameWinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  playerStats     PlayerMatchStats[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([matchId, gameNumber])
  @@index([matchId])
  @@index([blueTeamId, redTeamId])
}

model PlayerMatchStats {
  id                String      @id @default(cuid())
  playerId          String
  matchGameId       String
  teamId            String
  champion          String
  // Rôle joué dans cette game (par position, admin-corrigible), clé des
  // baselines de la note. Nullable pour les lignes antérieures au système.
  role              PlayerRole?
  kills             Int         @default(0)
  deaths            Int         @default(0)
  assists           Int         @default(0)
  cs                Int         @default(0)
  gold              Int         @default(0)
  damage            Int         @default(0)
  visionScore       Int         @default(0)
  side              String
  result            MatchResult
  kda               Float       @default(0)
  csPerMin          Float       @default(0)
  goldPerMin        Float       @default(0)
  damagePerMin      Float       @default(0)
  killParticipation Float       @default(0)
  damageShare       Float       @default(0)
  goldShare         Float       @default(0)
  // Champs bruts additionnels requis par la note (#9 tank) et le recompute.
  damageTakenPerMin Float       @default(0)
  rawDamageTaken    Int         @default(0)
  rawSelfMitigated  Int         @default(0)
  // Note de performance /100 + audit du moteur de valeur (§5.6 : idempotence
  // & rejouabilité). `note` est recalculable ; les `*Before/After` ne sont
  // écrits que lors de la 1re complétion de la game (pas de double application).
  note              Float?
  valueBefore       Int?
  valueAfter        Int?
  baselineAfter     Float?
  volatilityAfter   Float?
  items             Int[]       @default([])
  player            Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matchGame         MatchGame   @relation(fields: [matchGameId], references: [id], onDelete: Cascade)
  team              Team        @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt         DateTime    @default(now())

  @@unique([playerId, matchGameId])
  @@index([teamId])
  @@index([champion])
  @@index([result])
}

model MarketValueHistory {
  id            String   @id @default(cuid())
  playerId      String
  previousValue Int
  newValue      Int
  reason        String?
  changedById   String?
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  changedBy     User?    @relation("MarketValueChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedAt     DateTime @default(now())

  @@index([playerId, changedAt])
  @@index([changedById])
}

model Trophy {
  id          String   @id @default(cuid())
  name        String
  description String?
  seasonId    String
  teamId      String?
  playerId    String?
  awardedAt   DateTime @default(now())
  season      Season   @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  team        Team?    @relation("TeamTrophies", fields: [teamId], references: [id], onDelete: SetNull)
  player      Player?  @relation("PlayerTrophies", fields: [playerId], references: [id], onDelete: SetNull)

  @@index([seasonId, awardedAt])
  @@index([teamId])
  @@index([playerId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TransferOffer {
  id                 String              @id @default(cuid())
  playerId           String
  fromTeamId         String
  toTeamId           String
  offeredFee         Int
  status             TransferOfferStatus @default(PENDING)
  message            String?
  rejectionReason    String?
  counterOffer       Int?
  counterMessage     String?
  adminValidatedAt   DateTime?
  adminValidatedById String?
  finalizedAt        DateTime?
  linkedContractId   String?
  respondedAt        DateTime?
  player             Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromTeam           Team                @relation("BuyingTeam", fields: [fromTeamId], references: [id], onDelete: Restrict)
  toTeam             Team                @relation("SellingTeam", fields: [toTeamId], references: [id], onDelete: Restrict)
  linkedContract     Contract?           @relation("ContractTransfer", fields: [linkedContractId], references: [id], onDelete: SetNull)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([toTeamId, status])
  @@index([fromTeamId, status])
  @@index([playerId])
  @@index([linkedContractId])
}

model LeagueSettings {
  id                       Int       @id @default(1)
  boMaxRegularSeason       Int       @default(18)
  transferWindowOpen       Boolean   @default(true)
  transferWindowStart      DateTime?
  transferWindowEnd        DateTime?
  contractExpiryNoticeDays Int       @default(30)
  updatedAt                DateTime  @updatedAt
}

model BudgetConversion {
  id          String              @id @default(cuid())
  teamId      String
  direction   ConversionDirection
  amount      Int
  nUsed       Int
  createdById String
  createdAt   DateTime            @default(now())
  team        Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  balanceAfter Int
  type         String
  reason       String?
  matchId      String?
  playerId     String?
  betId        String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([matchId])
  @@index([betId])
}

model TeamRating {
  id          String   @id @default(cuid())
  teamId      String
  seasonId    String
  seedRating  Float
  rating      Float
  gamesPlayed Int      @default(0)
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season      Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt

  @@unique([teamId, seasonId])
  @@index([seasonId])
}

model MatchOdds {
  id         String   @id @default(cuid())
  matchId    String   @unique
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  probHome   Float
  probAway   Float
  oddsHome   Float
  oddsAway   Float
  margin     Float
  computedAt DateTime @updatedAt
}

model Bet {
  id              String    @id @default(cuid())
  userId          String
  matchId         String
  selectedTeamId  String
  stake           Int
  oddsAtBet       Float
  potentialPayout Int
  status          BetStatus @default(PENDING)
  placedAt        DateTime  @default(now())
  settledAt       DateTime?
  walletTxId      String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  selectedTeam    Team      @relation("BetSelectedTeam", fields: [selectedTeamId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([matchId, status])
}

model BettingConfig {
  seasonId          String   @id
  season            Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  margin            Float    @default(0.06)
  k                 Float    @default(24)
  warmupGames       Int      @default(2)
  seedRatingMin     Float    @default(1300)
  seedRatingMax     Float    @default(1700)
  probClampMin      Float    @default(0.10)
  probClampMax      Float    @default(0.90)
  minStake          Int      @default(1)
  maxStake          Int?
  allowSelfTeamBets Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model Champion {
  id           String       @id
  name         String
  title        String
  roles        PlayerRole[] @default([])
  splashUrl    String
  squareUrl    String
  patchVersion String
  enabled      Boolean      @default(true)
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())

  @@index([enabled])
}

model Draft {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  format       MatchFormat
  fearless     Boolean     @default(true)
  gameNumber   Int
  patchVersion String

  blueTeamId String
  blueTeam   Team   @relation("BlueTeamDrafts", fields: [blueTeamId], references: [id], onDelete: Restrict)
  redTeamId  String
  redTeam    Team   @relation("RedTeamDrafts", fields: [redTeamId], references: [id], onDelete: Restrict)

  status      DraftStatus @default(LOBBY)
  currentStep Int         @default(0)
  startedAt   DateTime?
  completedAt DateTime?

  coinflipWinnerTeamId String?
  coinflipWinnerTeam   Team?             @relation("CoinflipWinnerTeamDrafts", fields: [coinflipWinnerTeamId], references: [id], onDelete: SetNull)
  coinflipDecision     CoinflipDecision?
  coinflipResolvedAt   DateTime?

  // Result vote — captains must agree on the winner before stats are recorded
  // and before the next game in a BO3/BO5 series unlocks.
  blueResultVote DraftSide?
  redResultVote  DraftSide?
  winnerSide     DraftSide?
  winnerTeamId   String?
  winnerTeam     Team?      @relation("WonDrafts", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  resultLockedAt DateTime?

  // Next-game vote — once the winner is locked in a BO3/BO5, both captains
  // must confirm to spawn the next game. The losing team gets the coinflip
  // pick on the new draft.
  blueNextGameVote Boolean   @default(false)
  redNextGameVote  Boolean   @default(false)
  nextGameLockedAt DateTime?

  actions      DraftAction[]
  participants DraftParticipant[]

  createdById String
  createdBy   User   @relation("DraftCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([seasonId, status])
  @@index([status, createdAt])
  @@index([coinflipWinnerTeamId])
  @@index([winnerTeamId])
}

model DraftAction {
  id            String          @id @default(cuid())
  draftId       String
  draft         Draft           @relation(fields: [draftId], references: [id], onDelete: Cascade)
  step          Int
  type          DraftActionType
  side          DraftSide
  championId    String?
  championName  String?
  wasAutoPicked Boolean         @default(false)
  lockedAt      DateTime        @default(now())

  @@unique([draftId, step])
  @@index([draftId])
}

model DraftParticipant {
  id       String               @id @default(cuid())
  draftId  String
  draft    Draft                @relation(fields: [draftId], references: [id], onDelete: Cascade)
  userId   String
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     DraftParticipantRole
  joinedAt DateTime             @default(now())
  leftAt   DateTime?

  @@unique([draftId, userId])
  @@index([draftId])
}
