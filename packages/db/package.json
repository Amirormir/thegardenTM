{
  "name": "@nexus/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "build": "node scripts/with-root-env.mjs prisma generate --schema prisma/schema.prisma",
    "db:generate": "node scripts/with-root-env.mjs prisma generate --schema prisma/schema.prisma",
    "db:push": "node scripts/with-root-env.mjs tsx scripts/sync-legacy-db.ts && node scripts/with-root-env.mjs prisma db push --schema prisma/schema.prisma",
    "db:migrate": "node scripts/with-root-env.mjs prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "node scripts/with-root-env.mjs tsx prisma/seed.ts",
    "db:studio": "node scripts/with-root-env.mjs prisma studio --schema prisma/schema.prisma",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcryptjs": "3.0.3"
  },
  "devDependencies": {
    "@nexus/config": "workspace:*",
    "@types/node": "25.5.0",
    "prisma": "6.19.2",
    "tsx": "4.21.0"
  }
}
